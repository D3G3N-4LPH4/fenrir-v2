# ═══════════════════════════════════════════════════════════════════════════
#                   FENRIR PUMP.FUN BOT - CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
#
# CRITICAL SECURITY NOTES:
# 1. NEVER commit this file with real values to Git
# 2. Copy this to .env and fill in your actual values
# 3. Keep your private key secure - it controls your funds
# 4. Use a dedicated trading wallet, not your main wallet
#
# ═══════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────
# NETWORK CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────

# Solana RPC Endpoint
# Get a FREE endpoint from:
# - QuickNode: https://www.quicknode.com/
# - Helius: https://www.helius.dev/
# - Alchemy: https://www.alchemy.com/
# - Triton: https://triton.one/
#
# Public endpoints are rate-limited and unreliable for trading.
# For production, use a paid RPC with high rate limits.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# WebSocket URL (usually same as RPC but with wss://)
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# ───────────────────────────────────────────────────────────────────────────
# WALLET CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────

# Your wallet's private key (base58 encoded)
# 
# ⚠️  CRITICAL: This key controls real funds. Keep it SECRET.
#
# How to get your private key (from Phantom or Solflare):
# 1. Open wallet settings
# 2. Export private key
# 3. Copy the base58 string (NOT the secret recovery phrase)
# 
# Example format: 5J3mBbAH58CpQ3Y2S4bkVjMvN8KvVdR7u2K8V7x9...
#
# FOR TESTING: Leave blank - bot will generate a throwaway key in simulation mode
WALLET_PRIVATE_KEY=

# ───────────────────────────────────────────────────────────────────────────
# AI INTEGRATION (OPTIONAL - EXPERIMENTAL)
# ───────────────────────────────────────────────────────────────────────────

# OpenRouter API Key for AI-powered decision making
# Get one at: https://openrouter.ai/
# 
# When enabled, the bot can use Claude/GPT to analyze token launches
# and make smarter buy/sell decisions based on on-chain data
OPENROUTER_API_KEY=

# ───────────────────────────────────────────────────────────────────────────
# ADVANCED CONFIGURATION (OPTIONAL)
# ───────────────────────────────────────────────────────────────────────────

# Most settings are in the code or CLI args, but you can override here:

# Trading mode: simulation, conservative, aggressive, degen
# TRADING_MODE=simulation

# Buy amount in SOL
# BUY_AMOUNT_SOL=0.1

# Risk management
# STOP_LOSS_PCT=25
# TAKE_PROFIT_PCT=100
# TRAILING_STOP_PCT=15

# Launch criteria
# MIN_INITIAL_LIQUIDITY_SOL=5.0
# MAX_INITIAL_MARKET_CAP_SOL=100.0

# Execution settings
# PRIORITY_FEE_LAMPORTS=100000
# MAX_SLIPPAGE_BPS=500

# Logging
# LOG_LEVEL=INFO

# ───────────────────────────────────────────────────────────────────────────
# STRATEGY SELECTION (OPTIONAL)
# ───────────────────────────────────────────────────────────────────────────

# Comma-separated strategy IDs to run. Defaults to "sniper".
# Available: sniper, sniper_conservative, sniper_degen, graduation,
#            migration_snipe, reversal, volume_anomaly, narrative_tracker
# ENABLED_STRATEGIES=sniper

# ───────────────────────────────────────────────────────────────────────────
# PRE-TRADE FILTERS (OPTIONAL — off by default)
# ───────────────────────────────────────────────────────────────────────────

# Security hard-gate (mint/freeze authority, LP burn, holder concentration)
# SECURITY_FILTER_ENABLED=false
# SECURITY_REQUIRE_MINT_REVOKED=true
# SECURITY_REQUIRE_FREEZE_REVOKED=true
# SECURITY_MIN_LP_BURNED_PCT=90
# SECURITY_MAX_TOP10_HOLDER_PCT=30
# SECURITY_FAIL_OPEN_ON_HOLDER_FETCH_ERROR=false

# Optional Helius API key for enriched holder data (falls back to public RPC)
# HELIUS_API_KEY=

# Two-tier DexScreener market-condition filter
# MARKET_FILTER_ENABLED=false
# MARKET_FAIL_OPEN_ON_FETCH_ERROR=true

# ───────────────────────────────────────────────────────────────────────────
# TRANSACTION EXECUTION PROFILES (OPTIONAL — off by default)
# ───────────────────────────────────────────────────────────────────────────

# Use per-strategy tx profiles (slippage/priority-fee/Jito) instead of the flat
# PRIORITY_FEE_LAMPORTS / MAX_SLIPPAGE_BPS settings.
# TX_PROFILES_ENABLED=false
# Per-profile overrides honored by TxConfigManager:
# SNIPE_SLIPPAGE_PCT=25
# SNIPE_PRIORITY_FEE_SOL=0.02
# MOMENTUM_SLIPPAGE_PCT=8
# SWING_SLIPPAGE_PCT=2
# JITO_ENABLED=true
# JITO_TIP_SOL=0.001
