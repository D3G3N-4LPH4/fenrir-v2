# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# TypeScript incremental build cache (dashboard)
*.tsbuildinfo

# Virtual environments
venv/
.venv/
env/
.env

# IDE & tools
.vscode/
.idea/
.claude/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Process stdout/stderr redirect targets (e.g. launching the API detached with
# Start-Process -RedirectStandardOutput/-RedirectStandardError). These capture the
# RESOLVED config, which includes the RPC URL with its provider API key embedded —
# never commit them.
*.out
*.err

# Database files
*.db
*.db-*
*.sqlite3

# Secrets & credentials
.env
.env.local
.env.production
credentials.json
*_key.json

# Config overrides (keep example)
config/local.json
# Local runtime config (may hold real API keys) — use config/default.json as the
# tracked template and .env for secrets
/config.json
# Stray root-level editor settings (belongs in .vscode/, which is ignored)
/settings.json

# Node modules (if frontend exists)
node_modules/

# Testing
.pytest_cache/
htmlcov/
.coverage

# Distribution
*.tar.gz
*.whl
